# Consilium Backend — Environment Variables
# Copy to .env for local development or docker compose usage
# Local testing defaults to:
# - SQLite
# - development auth (no sign-in required)
# - Gemini when GEMINI_API_KEY is set

# Database
DATABASE_URL=sqlite:///./consilium.db
DATABASE_URL_ASYNC=

# Auth
AUTH_PROVIDER=development
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# LLM
GEMINI_API_KEY=
DEFAULT_MODEL=gemini-2.5-flash
GEMINI_SYNTHESIS_MODEL=gemini-2.5-flash-lite

# Vector Search
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=3072

# App
APP_ENV=local
APP_SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JOB_RUNNER_ENABLED=true
JOB_RUNNER_POLL_INTERVAL_SECONDS=0.25
JOB_RUNNER_STALE_AFTER_SECONDS=120

# Analytics (PostHog)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Error Monitoring (Sentry)
SENTRY_DSN=
