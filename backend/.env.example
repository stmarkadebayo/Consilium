# Consilium Backend — Environment Variables
# Copy to .env and fill in actual values

# Database
DATABASE_URL=postgresql://postgres.qnqgabtfjteqhpibibnw:[YOUR-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL_ASYNC=postgresql+asyncpg://consilium:password@localhost:5432/consilium

# Auth
AUTH_PROVIDER=supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-or-publishable-key

# LLM
GEMINI_API_KEY=
DEFAULT_MODEL=gemini-2.5-flash
GEMINI_SYNTHESIS_MODEL=gemini-2.5-flash-lite

# Vector Search
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=3072

# App
APP_ENV=local
APP_SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JOB_RUNNER_ENABLED=true
JOB_RUNNER_POLL_INTERVAL_SECONDS=0.25
JOB_RUNNER_STALE_AFTER_SECONDS=120

# Analytics (PostHog)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Error Monitoring (Sentry)
SENTRY_DSN=
